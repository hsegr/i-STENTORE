    {
      "name": "Keycloak Access Token",
      "item": [
        {
          "name": "Token Request from Keycloak",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = JSON.parse(pm.response.text());\r",
                  "var keycloakAccessToken = jsonData['access_token'];\r",
                  "pm.collectionVariables.set(\"keycloak_access_token\", keycloakAccessToken);"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "your_client_id",
                  "description": "Add your Client ID here",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "your_client_secret",
                  "description": "Add your Client Secret here",
                  "type": "text"
                },
                {
