                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "your_password",
                  "description": "Add your password here",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "https://iam.hse.gr/realms/i-STENTORE/protocol/openid-connect/token",
