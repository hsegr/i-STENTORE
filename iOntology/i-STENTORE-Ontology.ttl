    rdfs:label "Energy Arbitrage"@en ;
    rdfs:subClassOf :FlexOfferSchema .

:FCR a owl:Class ;
    rdfs:label "Frequency Containment Reserve"@en ;
    rdfs:subClassOf :FlexOfferSchema .

:FFR a owl:Class ;
    rdfs:label "Fast Frequency Response"@en ;
    rdfs:subClassOf :FlexOfferSchema .

:PowerSmoothing a owl:Class ;
    rdfs:label "Power Smoothing"@en ;
    rdfs:subClassOf :FlexOfferSchema .

:SynchronousInertia a owl:Class ;
    rdfs:label "Synchronous Inertia"@en ;
    rdfs:subClassOf :FlexOfferSchema .

:UFCS a owl:Class ;
    rdfs:label "UFCS"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :ChargingPower ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :EvSoC ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :TowerSOC ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :MaxCurrent ],
