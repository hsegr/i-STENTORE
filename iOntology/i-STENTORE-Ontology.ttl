:ActivePowerConsumptionTimeSeries a owl:Class ;
    rdfs:label "Active Power Consumption TimeSeries"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :ActivePowerConsumptionDataPoint ;
            owl:onProperty s4ener:includes ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :ActivePowerConsumptionDataPoint ;
            owl:onProperty s4ener:includes ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:duration ;
            owl:onProperty s4ener:hasTemporalResolution ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:dateTime ;
            owl:onProperty s4ener:hasCreationTime ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass time:Interval ;
            owl:onProperty s4ener:hasEffectivePeriod ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        s4ener:TimeSeries .

