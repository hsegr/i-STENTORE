#################################################################
# Flexibility service classes
#################################################################

:PeakShaving a owl:Class ;
    rdfs:label "Peak Shaving"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty s4ener:includes ;
            owl:someValuesFrom s4ener:TimeSeries ],
        [ a owl:Restriction ;
            owl:onProperty saref:producedBy ;
            owl:someValuesFrom :Demos_Virtual_Devices ],
        :FlexOfferSchema,
        s4ener:FlexOffer .

:FlexOfferSchema a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass s4ener:TimeSeries ;
            owl:onProperty s4ener:includes ],
        [ a owl:Restriction ;
            owl:onClass time:Interval ;
            owl:onProperty s4ener:hasEffectivePeriod ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Demos_Virtual_Devices ;
            owl:onProperty saref:producedBy ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:dateTime ;
            owl:onProperty s4ener:hasCreationTime ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        s4ener:FlexOffer .

#################################################################
# Auxiliary classes and remaining declarations
#################################################################

:CongestionManagement a owl:Class ;
    rdfs:label "Congestion Management"@en ;
    rdfs:subClassOf :FlexOfferSchema .

:EmotionTower a owl:Class ;
    rdfs:label "EmotionTower"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :ChargingPower ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :EvSoC ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :MaxCurrent ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :Voltage ],
        :EVChargingUnit .

:EmotionV2G a owl:Class ;
    rdfs:label "EmotionV2G"@en ;
