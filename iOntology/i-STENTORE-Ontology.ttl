:ActivePowerConsumption a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Active Power Consumption"@en .
:WholesaleMarketPrice a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Wholesale Market Price"@en .
:UpwardReservePrice a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Upward Reserve Price"@en .
:DownwardReservePrice a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Downward Reserve Price"@en .
:EvSoC a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "EV SoC"@en .
:TowerSOC a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Tower SoC"@en .
:MaxCurrent a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Max Current"@en .
:Voltage a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Voltage"@en .
:PowerL1 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Power L1"@en .
:PowerL2 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Power L2"@en .
:PowerL3 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Power L3"@en .
:PowerTotal a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Power Total"@en .
:CurrentL1 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Current L1"@en .
:CurrentL2 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Current L2"@en .
:CurrentL3 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Current L3"@en .
:VoltageL1N a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Voltage L1-N"@en .
:VoltageL2N a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Voltage L2-N"@en .
:VoltageL3N a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Voltage L3-N"@en .
:VoltageL1L2 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Voltage L1-L2"@en .
:VoltageL1L3 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Voltage L1-L3"@en .
:VoltageL2L3 a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Voltage L2-L3"@en .
:StateOfCharge a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "State Of Charge (Percent)"@en .
:TimeToFull a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Time To Full"@en .
:TimeToEmpty a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Time To Empty"@en .
:StatusString a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Status (String)"@en .
:L1Power a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "L1 Power"@en .
:L2Power a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "L2 Power"@en .
:L3Power a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "L3 Power"@en .
:PEMRatedPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "PEM Rated Power"@en .
:CompressorRatedPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Compressor Rated Power"@en .
:HydrogenLHV a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Hydrogen LHV"@en .
