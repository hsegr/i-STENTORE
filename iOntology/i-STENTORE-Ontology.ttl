#################################################################
# Device / storage classes (assets) and their required properties
#################################################################

:Furnace a owl:Class ; rdfs:label "Furnace"@en ; rdfs:subClassOf s4ener:Device
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :RatedPower ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :EnergyCapacity ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :ChargeRate ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :DischargeRate ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :GlassMeltTemperature ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :Efficiency ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :BoosterPower ] .

:PVPlant a owl:Class ; rdfs:label "PVPlant"@en ; rdfs:subClassOf s4ener:Device
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :NominalPower ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :PeakPower ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :Orientation ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :Inclination ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :SunIrradiance ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :StandardIrradiance ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :EfficiencyOfPanel ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :OutputActivePower ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :OutputReactivePower ] .

:WindTurbine a owl:Class ; rdfs:label "WindTurbine"@en ; rdfs:subClassOf s4ener:Device
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :NominalPower ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :InstalledCapacity ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :CutInSpeed ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :CutOutSpeed ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :ReferenceSpeed ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :WindSpeed ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :OutputActivePower ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :OutputReactivePower ] .

:HydroPlant a owl:Class ; rdfs:label "HydroPlant"@en ; rdfs:subClassOf s4ener:Device
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :RatedPower ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :Inflow ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :HydraulicHead ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :PlantEfficiency ]
  , [ a owl:Restriction ; owl:onProperty saref:hasProperty ; owl:someValuesFrom :InflowUpperLimit ]
