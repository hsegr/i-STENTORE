#################################################################
# Dynamic property scaffolding (DataPoint + TimeSeries)
# DataPoint enforces unit+datatype at saref:PropertyValue level.
# TimeSeries constrains s4ener:includes to the matching DataPoint and adds schema constraints.
#################################################################

:GlassMeltTemperatureDataPoint a owl:Class ; rdfs:subClassOf s4ener:DataPoint ; rdfs:label "Glass Melt Temperature DataPoint"@en ;
  rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:observes ; owl:hasValue :GlassMeltTemperature ] ;
  rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:hasResult ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :PV_Unit_degreeCelsius_Float ] .

