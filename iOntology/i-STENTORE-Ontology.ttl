  rdfs:subClassOf [ a owl:Restriction ; owl:onProperty s4ener:includes ; owl:allValuesFrom :GlassMeltTemperatureDataPoint ] ;
  rdfs:subClassOf [ a owl:Restriction ; owl:onProperty s4ener:includes ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :GlassMeltTemperatureDataPoint ] ;
