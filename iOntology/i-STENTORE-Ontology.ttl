#################################################################
# i-STENTORE Ontology v2.0
#################################################################

@base <https://hse.gr/pub/i-stentore/ontology/v2.0/> .
@prefix : <https://hse.gr/pub/i-stentore/ontology/v2.0/> .
@prefix istentore: <https://hse.gr/pub/i-stentore/ontology/v2.0/> .

@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix saref: <https://saref.etsi.org/core/> .
@prefix s4ener: <https://saref.etsi.org/saref4ener/> .

@prefix time: <http://www.w3.org/2006/time#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .

#################################################################
# Ontology metadata and imports
#################################################################

<https://hse.gr/pub/i-stentore/ontology/v2.0> a owl:Ontology ;
    dcterms:description "The i-STENTORE ontology v2.0 extends SAREF and SAREF4ENER to model energy assets, static and dynamic properties, DataPoints, TimeSeries, and flexibility services used in the i-STENTORE digital ecosystem."@en ;
    dcterms:issued "2026-06-29"^^xsd:date ;
    dcterms:license <https://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:modified "2026-06-29"^^xsd:date ;
    dcterms:publisher <https://hse.gr/> ;
    dcterms:title "i-STENTORE Ontology"@en ;
    vann:preferredNamespacePrefix "istentore" ;
    vann:preferredNamespaceUri "https://hse.gr/pub/i-stentore/ontology/v2.0/" ;
    owl:imports qudt:,
        om:,
        <http://www.w3.org/2006/time>,
        saref:,
        s4ener: ;
    owl:versionIRI <https://hse.gr/pub/i-stentore/ontology/v2.0> ;
    owl:versionInfo "v2.0" .

#################################################################
# Minimal external declarations
#################################################################

s4ener:hasCreationTime a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

s4ener:hasEffectivePeriod a owl:ObjectProperty ;
    rdfs:range time:Interval .

s4ener:hasTemporalResolution a owl:DatatypeProperty ;
    rdfs:range xsd:duration .

#################################################################
# Units of measure
#################################################################

unit:A a saref:UnitOfMeasure ;
    rdfs:label "A"@en .

unit:Ampere a saref:UnitOfMeasure .

unit:BAR a saref:UnitOfMeasure ;
    rdfs:label "bar"@en .

unit:DEG a saref:UnitOfMeasure ;
    rdfs:label "°"@en .

unit:DEG_C a saref:UnitOfMeasure ;
    rdfs:label "°C"@en .

unit:DegreeCelsius a saref:UnitOfMeasure .

unit:KiloGM a saref:UnitOfMeasure ;
    rdfs:label "kg"@en .

unit:KiloGM-PER-HR a saref:UnitOfMeasure ;
    rdfs:label "kg/h"@en .

unit:KiloV-A a saref:UnitOfMeasure ;
    rdfs:label "kVA"@en .

unit:KiloVAR a saref:UnitOfMeasure ;
    rdfs:label "kVAr"@en .

unit:KiloW a saref:UnitOfMeasure ;
    rdfs:label "kW"@en .

unit:KiloW-HR a saref:UnitOfMeasure ;
    rdfs:label "kWh"@en .

unit:M a saref:UnitOfMeasure ;
    rdfs:label "m"@en .

unit:M-PER-SEC a saref:UnitOfMeasure ;
    rdfs:label "m/s"@en .

unit:M3 a saref:UnitOfMeasure ;
    rdfs:label "m^3"@en .

unit:M3-PER-SEC a saref:UnitOfMeasure ;
    rdfs:label "m3/s"@en .

unit:MIN a saref:UnitOfMeasure ;
    rdfs:label "min"@en .

unit:MegaV-A a saref:UnitOfMeasure ;
    rdfs:label "MVA"@en .

unit:MegaW a saref:UnitOfMeasure ;
    rdfs:label "MW"@en .

unit:PERCENT a saref:UnitOfMeasure ;
    rdfs:label "%"@en .

unit:UNITLESS a saref:UnitOfMeasure ;
    rdfs:label "unitless"@en .

unit:V a saref:UnitOfMeasure ;
    rdfs:label "V"@en .

unit:Volt a saref:UnitOfMeasure .

unit:W a saref:UnitOfMeasure ;
    rdfs:label "W"@en .

unit:W-PER-M2 a saref:UnitOfMeasure ;
    rdfs:label "W/m2"@en .

:KiloW-Peak a saref:UnitOfMeasure ;
    rdfs:label "kWp"@en .

:Unit_CRate a saref:UnitOfMeasure ;
    rdfs:label "C-rate"@en .

:Unit_EUR a saref:UnitOfMeasure ;
    rdfs:label "EUR"@en,
        "€"@en .

:Unit_EUR_per_MWh a saref:UnitOfMeasure ;
    rdfs:label "€/MWh"@en .

:Unit_EUR_per_kWh a saref:UnitOfMeasure ;
    rdfs:label "€/kWh"@en .

:Unit_OffOn a saref:UnitOfMeasure ;
    rdfs:label "0-off / 1-on"@en .

:Unit_String a saref:UnitOfMeasure ;
    rdfs:label "string"@en .

:Unit_W_per_m2 a saref:UnitOfMeasure ;
    rdfs:label "W/m2"@en .

:Unit_kWh_per_kg a saref:UnitOfMeasure ;
    rdfs:label "kWh/kg"@en .

:Unit_min a saref:UnitOfMeasure ;
    rdfs:label "min"@en .

:Unit_pu a saref:UnitOfMeasure ;
    rdfs:label "p.u"@en .

:Unit_pu_dot a saref:UnitOfMeasure ;
    rdfs:label "p.u."@en .

#################################################################
# Property-value helper classes
#################################################################

:PV_Unit_Ampere_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_Ampere ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_EUR_per_MWh_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_EUR_per_MWh ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_OffOn_Integer a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_OffOn ;
            owl:onProperty saref:isMeasuredIn ],
        :IntegerPropertyValue .

:PV_Unit_Percent_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_Percent ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_String_String a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_String ;
            owl:onProperty saref:isMeasuredIn ],
        :StringPropertyValue .

:PV_Unit_Volt_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_Volt ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_W_per_m2_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_W_per_m2 ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_bar_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_bar ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_degreeCelsius_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_degreeCelsius ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_kVAr_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_kVAr ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_kW_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_kW ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_kWh_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_kWh ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_m3_per_s_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_m3_per_s ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_m_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_m ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_m_per_s_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_m_per_s ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_min_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_min ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:PV_Unit_pu_dot_Float a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :Unit_pu_dot ;
            owl:onProperty saref:isMeasuredIn ],
        :FloatPropertyValue .

:IntegerPropertyValue a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty saref:hasValue ],
        saref:PropertyValue .

:StringPropertyValue a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty saref:hasValue ],
        saref:PropertyValue .

:FloatPropertyValue a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty saref:hasValue ],
        saref:PropertyValue .

