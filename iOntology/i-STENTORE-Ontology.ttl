#################################################################
# Aggregated virtual devices + FlexOffer subclasses for demo services
#################################################################

:Demos_Virtual_Devices a owl:Class ;
  rdfs:label "Demos virtual devices"@en ;
  rdfs:subClassOf s4ener:Device .

:FlexOfferSchema a owl:Class ;
  rdfs:subClassOf s4ener:FlexOffer ;
  rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty s4ener:includes ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass s4ener:TimeSeries ] ,
    [ a owl:Restriction ; owl:onProperty s4ener:hasEffectivePeriod ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass time:Interval ] ,
    [ a owl:Restriction ; owl:onProperty saref:producedBy ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :Demos_Virtual_Devices ] ,
    [ a owl:Restriction ; owl:onProperty s4ener:hasCreationTime ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onDataRange xsd:dateTime ] .

:PeakShaving a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Peak Shaving"@en .
:CongestionManagement a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Congestion Management"@en .
:EnergyArbitrage a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Energy Arbitrage"@en .
:PowerSmoothing a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Power Smoothing"@en .
:SynchronousInertia a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Synchronous Inertia"@en .
:FFR a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Fast Frequency Response"@en .
:FCR a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Frequency Containment Reserve"@en .
:aFRR a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Automatic Frequency Restoration Reserve"@en .
:mFRR a owl:Class ; rdfs:subClassOf :FlexOfferSchema ; rdfs:label "Manual Frequency Restoration Reserve"@en .