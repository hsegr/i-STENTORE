
#################################################################
# Unit declarations (QUDT units reused as saref:UnitOfMeasure)
#################################################################

unit:KiloW a saref:UnitOfMeasure .
unit:KiloW-HR a saref:UnitOfMeasure .
unit:Volt a saref:UnitOfMeasure .
unit:Ampere a saref:UnitOfMeasure .
unit:DegreeCelsius a saref:UnitOfMeasure .

#################################################################
# Static properties (subclasses of saref:Property)
# Pattern: restriction on saref:isMeasuredIn using owl:hasValue
# (as described in iOntology presentation):contentReference[oaicite:0]{index=0}
#################################################################

:RatedPower
  a owl:Class ;
  rdfs:subClassOf saref:Property ,
    [
      a owl:Restriction ;
      owl:onProperty saref:isMeasuredIn ;
      owl:hasValue unit:KiloW
    ] .

:EnergyCapacity
  a owl:Class ;
  rdfs:subClassOf saref:Property ,
    [
      a owl:Restriction ;
      owl:onProperty saref:isMeasuredIn ;
      owl:hasValue unit:KiloW-HR
    ] .

:TechnicalMinimum
  a owl:Class ;
  rdfs:subClassOf saref:Property .

:ReservoirMaxCapacity
  a owl:Class ;
  rdfs:subClassOf saref:Property .

:ReservoirMinCapacity
  a owl:Class ;
  rdfs:subClassOf saref:Property .

#################################################################
# Dynamic property example (Property -> DataPoint -> TimeSeries)
# Pattern per iOntology presentation: keep Property simple, enforce
# unit/datatype at DataPoint level, link TimeSeries to DataPoint:contentReference[oaicite:1]{index=1}
#################################################################

:OutputActivePower
  a owl:Class ;
  rdfs:subClassOf saref:Property .

:OutputActivePowerDataPoint
  a owl:Class ;
  rdfs:subClassOf s4ener:DataPoint ,
    [
      a owl:Restriction ;
      owl:onProperty saref:observes ;
      owl:hasValue :OutputActivePower
    ] .

:OutputActivePowerTimeSeries
  a owl:Class ;
  rdfs:subClassOf s4ener:TimeSeries ,
    [
      a owl:Restriction ;
      owl:onProperty s4ener:hasDataPoint ;
      owl:allValuesFrom :OutputActivePowerDataPoint
    ] .

#################################################################
# Device / asset classes (subclasses of s4ener:Device / s4ener:Storage)
# Pattern per iOntology presentation:contentReference[oaicite:2]{index=2}
#################################################################

:PVPlant
  a owl:Class ;
  rdfs:subClassOf s4ener:Device ,
    [
      a owl:Restriction ;
      owl:onProperty saref:hasProperty ;
      owl:someValuesFrom :RatedPower
    ] .

:HydroelectricPlant
  a owl:Class ;
  rdfs:subClassOf s4ener:Device .

:ReservoirHydroPlant
  a owl:Class ;
  rdfs:subClassOf :HydroelectricPlant .

:ThermalGenerator
  a owl:Class ;
  rdfs:subClassOf s4ener:Device .

:LithiumIonBattery
  a owl:Class ;
  rdfs:subClassOf s4ener:Storage .

:VRFBBattery
  a owl:Class ;
  rdfs:subClassOf s4ener:Storage .

:ThermalStorage
  a owl:Class ;
  rdfs:subClassOf s4ener:Storage .

:HydrogenStorage
  a owl:Class ;
  rdfs:subClassOf s4ener:Storage .

:EVChargingUnit
  a owl:Class ;
  rdfs:subClassOf s4ener:Device .

:EmotionTower
  a owl:Class ;
  rdfs:subClassOf :EVChargingUnit .

:UFCS
  a owl:Class ;
  rdfs:subClassOf :EVChargingUnit .

:EmotionV2G
  a owl:Class ;
  rdfs:subClassOf :EVChargingUnit .

:SmartMeter
  a owl:Class ;
  rdfs:subClassOf s4ener:Device .

:Fillepro
  a owl:Class ;
  rdfs:subClassOf s4ener:Storage .


#################################################################
# Flexibility / scheduling service classes (subclasses of s4ener:FlexOffer)
# Pattern per iOntology presentation and handoff redesign guide:contentReference[oaicite:4]{index=4}:contentReference[oaicite:5]{index=5}
#################################################################

:PeakShaving
  a owl:Class ;
  rdfs:subClassOf s4ener:FlexOffer ,
    [
      a owl:Restriction ;
      owl:onProperty s4ener:includes ;
      owl:someValuesFrom s4ener:TimeSeries
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty saref:producedBy ;
      owl:someValuesFrom :Demos_Virtual_Devices
    ] .







@base <http://www.hse.gr/i-stentore/ontology#> .
@prefix : <http://www.hse.gr/i-stentore/ontology#> .
@prefix istentore: <http://www.hse.gr/i-stentore/ontology#> .

@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix saref: <https://saref.etsi.org/core/> .
@prefix s4ener: <https://saref.etsi.org/saref4ener/> .

@prefix time: <http://www.w3.org/2006/time#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .

<http://www.hse.gr/i-stentore/ontology>
    a owl:Ontology ;
    owl:versionInfo "v1.9" ;
    owl:versionIRI <http://www.hse.gr/i-stentore/ontology/v1.9> ;
    owl:priorVersion <http://www.hse.gr/i-stentore/ontology/v1.6> ;
    dcterms:issued "2026-03-05"^^xsd:date ;
    dcterms:modified "2026-03-05"^^xsd:date ;
    dcterms:title "i-STENTORE Ontology"@en ;
    dcterms:publisher <https://hse.gr/> ;
    dcterms:license <https://forge.etsi.org/etsi-software-license> ;
    dcterms:creator <https://www.linkedin.com/in/dimitrios-kranias/> ;
    dcterms:source <https://saref.etsi.org/sources/saref-core/> ;
    rdfs:seeAlso <https://saref.etsi.org/core/v4.1.1/> ;
    rdfs:seeAlso <https://saref.etsi.org/saref4ener/v2.1.1/> ;
    vann:preferredNamespacePrefix "istentore" ;
    vann:preferredNamespaceUri "http://www.hse.gr/i-stentore/ontology#" ;
    dcterms:description "The i-STENTORE ontology extends SAREF and SAREF4ENER to model energy assets, measurements (DataPoints) and TimeSeries, and flexibility services (FlexOffers) used in i-STENTORE demos."@en .

#################################################################
# Minimal declarations for SAREF4ENER properties used in restrictions
#################################################################

s4ener:hasTemporalResolution a owl:DatatypeProperty ; rdfs:range xsd:duration .
s4ener:hasCreationTime a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
s4ener:hasEffectivePeriod a owl:ObjectProperty ; rdfs:range time:Interval .

#################################################################
# Units of measure
# Units are individuals of saref:UnitOfMeasure.
#################################################################


# Dimensionless
unit:PERCENT a saref:UnitOfMeasure ; rdfs:label "%"@en .
unit:UNITLESS a saref:UnitOfMeasure ; rdfs:label "unitless"@en .

# Electric / power / energy
unit:A a saref:UnitOfMeasure ; rdfs:label "A"@en .
unit:V a saref:UnitOfMeasure ; rdfs:label "V"@en .
unit:W a saref:UnitOfMeasure ; rdfs:label "W"@en .
unit:KiloW a saref:UnitOfMeasure ; rdfs:label "kW"@en .
unit:MegaW a saref:UnitOfMeasure ; rdfs:label "MW"@en .
unit:KiloV-A a saref:UnitOfMeasure ; rdfs:label "kVA"@en .
unit:MegaV-A a saref:UnitOfMeasure ; rdfs:label "MVA"@en .
unit:KiloVAR a saref:UnitOfMeasure ; rdfs:label "kVAr"@en .
unit:KiloW-HR a saref:UnitOfMeasure ; rdfs:label "kWh"@en .

# Length / speed / volume / flow
unit:M a saref:UnitOfMeasure ; rdfs:label "m"@en .
unit:M-PER-SEC a saref:UnitOfMeasure ; rdfs:label "m/s"@en .
unit:M3 a saref:UnitOfMeasure ; rdfs:label "m^3"@en .
unit:M3-PER-SEC a saref:UnitOfMeasure ; rdfs:label "m3/s"@en .

# Irradiance
unit:W-PER-M2 a saref:UnitOfMeasure ; rdfs:label "W/m2"@en .

# Mass / mass flow
unit:KiloGM a saref:UnitOfMeasure ; rdfs:label "kg"@en .
unit:KiloGM-PER-HR a saref:UnitOfMeasure ; rdfs:label "kg/h"@en .

# Pressure
unit:BAR a saref:UnitOfMeasure ; rdfs:label "bar"@en .

# Time
unit:MIN a saref:UnitOfMeasure ; rdfs:label "min"@en .

# Temperature
unit:DEG_C a saref:UnitOfMeasure ; rdfs:label "°C"@en .

# Angle (degree)
unit:DEG a saref:UnitOfMeasure ; rdfs:label "°"@en .

# --- Domain / project-specific units that are not standard QUDT/OM units ---

# C-rate is not a physical unit; treat as dimensionless rate and label explicitly
:Unit_CRate a saref:UnitOfMeasure ; rdfs:label "C-rate"@en .

# Currency units are not in QUDT/OM in a clean way; keep project-local
:Unit_EUR a saref:UnitOfMeasure ;
    rdfs:label "EUR"@en ;
    rdfs:label "€"@en .
:Unit_EUR_per_MWh a saref:UnitOfMeasure ; rdfs:label "€/MWh"@en .
:Unit_EUR_per_kWh a saref:UnitOfMeasure ; rdfs:label "€/kWh"@en .

# Enumerations / string values are not UnitsOfMeasure; if you MUST keep it:
# (Better: use xsd:string without a unit)
:Unit_OffOn a saref:UnitOfMeasure ; rdfs:label "0-off / 1-on"@en .
:Unit_String a saref:UnitOfMeasure ; rdfs:label "string"@en .

### To be deleted
:Unit_W_per_m2 a saref:UnitOfMeasure ; rdfs:label "W/m2"@en .
:Unit_kWh_per_kg a saref:UnitOfMeasure ; rdfs:label "kWh/kg"@en .
:KiloW-Peak a saref:UnitOfMeasure ; rdfs:label "kWp"@en .

:Unit_min a saref:UnitOfMeasure ; rdfs:label "min"@en .
:Unit_pu a saref:UnitOfMeasure ; rdfs:label "p.u"@en .
:Unit_pu_dot a saref:UnitOfMeasure ; rdfs:label "p.u."@en .

#################################################################
# PropertyValue typing helpers (reused by DataPoint constraints)
#################################################################

:FloatPropertyValue a owl:Class ; rdfs:subClassOf saref:PropertyValue ;
  rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:hasValue ; owl:allValuesFrom xsd:float ] .

:IntegerPropertyValue a owl:Class ; rdfs:subClassOf saref:PropertyValue ;
  rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:hasValue ; owl:allValuesFrom xsd:integer ] .

:StringPropertyValue a owl:Class ; rdfs:subClassOf saref:PropertyValue ;
  rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:hasValue ; owl:allValuesFrom xsd:string ] .

:PV_Unit_Percent_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_Percent ] .
:PV_Unit_Ampere_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_Ampere ] .
:PV_Unit_Volt_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_Volt ] .
:PV_Unit_W_per_m2_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_W_per_m2 ] .
:PV_Unit_bar_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_bar ] .
:PV_Unit_kVAr_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_kVAr ] .
:PV_Unit_kW_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_kW ] .
:PV_Unit_kWh_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_kWh ] .
:PV_Unit_m_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_m ] .
:PV_Unit_m3_per_s_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_m3_per_s ] .
:PV_Unit_m_per_s_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_m_per_s ] .
:PV_Unit_min_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_min ] .
:PV_Unit_pu_dot_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_pu_dot ] .
:PV_Unit_degreeCelsius_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_degreeCelsius ] .
:PV_Unit_EUR_per_MWh_Float a owl:Class ; rdfs:subClassOf :FloatPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_EUR_per_MWh ] .
:PV_Unit_OffOn_Integer a owl:Class ; rdfs:subClassOf :IntegerPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_OffOn ] .
:PV_Unit_String_String a owl:Class ; rdfs:subClassOf :StringPropertyValue ; rdfs:subClassOf [ a owl:Restriction ; owl:onProperty saref:isMeasuredIn ; owl:hasValue :Unit_String ] .

#################################################################
# Properties (Static & Dynamic)
# Dynamic properties use the Property → DataPoint → TimeSeries pattern.
#################################################################

:RatedPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Rated Power"@en .
:EnergyCapacity a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Energy Capacity"@en .
:ChargeRate a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Charge Rate"@en .
:DischargeRate a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Discharge Rate"@en .
:GlassMeltTemperature a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Glass Melt Temperature"@en .
:Efficiency a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Efficiency"@en .
:BoosterPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Booster Power"@en .
:NominalPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Nominal Power"@en .
:InstalledCapacity a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Installed Capacity"@en .
:CutInSpeed a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Cut-in Speed"@en .
:CutOutSpeed a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Cut-out Speed"@en .
:ReferenceSpeed a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Reference Speed"@en .
:WindSpeed a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Wind Speed"@en .
:Orientation a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Orientation"@en .
:Inclination a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Inclination"@en .
:PeakPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Peak Power"@en .
:SunIrradiance a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Sun Irradiance"@en .
:StandardIrradiance a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Standard Irradiance"@en .
:EfficiencyOfPanel a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Efficiency Of Panel"@en .
:OutputPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Output Power"@en .
:OutputActivePower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Output Active Power"@en .
:OutputReactivePower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Output Reactive Power"@en .
:Inflow a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Inflow"@en .
:HydraulicHead a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Hydraulic Head"@en .
:PlantEfficiency a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Plant Efficiency"@en .
:InflowUpperLimit a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Inflow Upper Limit"@en .
:InflowLowerLimit a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Inflow Lower Limit"@en .
:ReservoirMaxCapacity a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Reservoir Max Capacity"@en .
:ReservoirMinCapacity a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Reservoir Min Capacity"@en .
:ReservoirStatus a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Reservoir Status"@en .
:ConverterRating a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Converter Rating"@en .
:ChargingPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Charging Power"@en .
:DischargingPower a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Discharging Power"@en .
:MaximumSOC a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Maximum SOC"@en .
:MinimumSOC a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Minimum SOC"@en .
:SOC a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "State Of Charge (Energy)"@en .
:ChargingEfficiency a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Charging Efficiency"@en .
:DischargingEfficiency a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Discharging Efficiency"@en .
:CalendarDegradationCost a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Calendar Degradation Cost"@en .
:Param1CalendarDeg a owl:Class ; rdfs:subClassOf saref:Property ; rdfs:label "Param 1 Calendar Degradation"@en .
