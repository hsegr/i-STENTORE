#################################################################
# Device / asset classes
#################################################################

:AlkalineHydrogenElectrolyzer a owl:Class ;
    rdfs:label "Alkaline Hydrogen Electrolyzer"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Device ;
    owl:equivalentClass :PEMElectrolyzerCompressor .

:BatteryEVChargingStationG2V a owl:Class ;
    rdfs:label "Battery EVCharging Station G2 V"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Device ;
    owl:equivalentClass :EmotionTower .

:Demos_Virtual_Devices a owl:Class ;
    rdfs:label "Demos virtual devices"@en ;
    rdfs:subClassOf s4ener:Device .

:EVChargingStationG2V a owl:Class ;
    rdfs:label "EVCharging Station G2 V"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Device ;
    owl:equivalentClass :EVChargingUnit .

:EVChargingStationV2G a owl:Class ;
    rdfs:label "EVCharging Station V2 G"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Device ;
    owl:equivalentClass :EmotionV2G .

:ElectricFurnace a owl:Class ;
    rdfs:label "Electric Furnace"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Device ;
    owl:equivalentClass :Furnace .

:EnergyMarket a owl:Class ;
    rdfs:label "EnergyMarket"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :WholesaleMarketPrice ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :UpwardReservePrice ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :DownwardReservePrice ],
        s4ener:Device .

:Fillepro a owl:Class ;
    rdfs:label "Fillepro"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :StateOfCharge ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :TimeToFull ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :TimeToEmpty ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :StatusString ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :L1Power ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :L2Power ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :L3Power ],
        s4ener:Storage .

:HydroPlant a owl:Class ;
    rdfs:label "HydroPlant"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :RatedPower ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :Inflow ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :HydraulicHead ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :PlantEfficiency ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :InflowUpperLimit ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :InflowLowerLimit ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :OutputActivePower ],
        s4ener:Device .

:HydroPump a owl:Class ;
    rdfs:label "HydroPump"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :NominalPower ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :InstalledCapacity ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :Efficiency ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :PowerConsumption ],
        s4ener:Device .

:HydroelectricPlantReservoir a owl:Class ;
    rdfs:label "Hydroelectric Plant Reservoir"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Device ;
    owl:equivalentClass :ReservoirHydroPlant .

:HydrogenStorage a owl:Class ;
    rdfs:label "HydrogenStorage"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :StorageTankPressure ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :MaximumTankH2MassLevel ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :MaximumH2EnergyStorage ],
        s4ener:Storage .

:Lithium-IonBattery a owl:Class ;
    rdfs:label "Lithium Ion Battery"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Storage ;
    owl:equivalentClass :LiIonBattery .

:LithiumIonBattery a owl:Class ;
    rdfs:subClassOf s4ener:Storage .

:PhotovoltaicPlant a owl:Class ;
    rdfs:label "Photovoltaic Plant"@en ;
    rdfs:comment "Alias included to align the Turtle ontology with the i-STENTORE JSON-LD context v2.0."@en ;
    rdfs:subClassOf s4ener:Device ;
    owl:equivalentClass :PVPlant .

:SmartMeter a owl:Class ;
    rdfs:label "SmartMeter"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :PowerL1 ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :PowerL2 ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :PowerL3 ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :PowerTotal ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :CurrentL1 ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :CurrentL2 ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :CurrentL3 ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :VoltageL1N ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :VoltageL2N ],
        [ a owl:Restriction ;
            owl:onProperty saref:hasProperty ;
            owl:someValuesFrom :VoltageL3N ],
